---
- name: install nginx andd started
  hosts: servers
  become: yes
  tasks:
    - name: install nginx
      apt:
        name: nginx
        state: latest
    - name: start nginx
      service:
        name: nginx
        state: started
        enabled: yes
    - name: deploy
      copy:
        src: index.html
        dest: /var/www/html
